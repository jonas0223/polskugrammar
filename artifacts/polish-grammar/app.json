{
  "expo": {
    "name": "Polish Grammar Practice",
    "slug": "polish-grammar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "polish-grammar",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#054013"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.polishgrammar.practice"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#054013"
      },
      "package": "com.polskugrammar.app",
      "versionCode": 6
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "cc15d636-642a-462e-8703-0844b3c3ccfa"
      }
    }
  }
}
